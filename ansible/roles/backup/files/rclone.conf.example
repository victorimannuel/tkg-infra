# rclone.conf.example — Google Drive remote configuration template
# 
# CARA SETUP:
# 1. Di local machine, jalankan: rclone config
# 2. Buat remote baru, pilih "Google Drive", ikuti wizard
# 3. Setelah selesai, copy isi ~/.config/rclone/rclone.conf ke sini
# 4. Simpan sebagai ansible/roles/backup/files/rclone.conf (file ini di-ignore git)
#
# CONTOH FORMAT (ganti dengan nilai asli dari rclone config):
# [gdrive]
# type = drive
# client_id = YOUR_CLIENT_ID
# client_secret = YOUR_CLIENT_SECRET
# scope = drive
# token = {"access_token":"...","token_type":"Bearer","refresh_token":"...","expiry":"..."}
# team_drive =

[gdrive]
type = drive
scope = drive
# Paste your token here after running: rclone config
